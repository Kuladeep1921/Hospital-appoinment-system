# Backend Environment Variables
# Copy this file to .env and fill in the actual values

PORT=5000
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/hospital_booking?appName=Cluster0
JWT_SECRET=your_super_secret_jwt_key_here
NODE_ENV=production

# The deployed Render URL of your frontend (set this after deploying frontend on Render)
FRONTEND_URL=https://your-frontend-name.onrender.com
